# Skill environment variables (copy to .env; never commit the real .env)

# BSC testnet RPC endpoint used by viem.
BSC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Private key of the agent wallet that receives payouts and signs submissions.
AGENT_PRIVATE_KEY=

# HTTP base URL of the grader service (e.g. http://localhost:8765).
GRADER_URL=http://localhost:8765

# Deployed ERC-8183 JobFactory contract address.
ERC8183_ADDRESS=0x3464e64dD53bC093c53050cE5114062765e9F1b6

# Deployed GraderEvaluator contract address.
GRADER_EVALUATOR_ADDRESS=
