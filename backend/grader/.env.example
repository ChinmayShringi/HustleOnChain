# Grader service environment variables (copy to .env; never commit the real .env)

# Private key that signs verdict messages and calls GraderEvaluator.submitVerdict.
# Must match GRADER_EVALUATOR_ADDRESS below. Never commit this value.
EVALUATOR_PRIVATE_KEY=

# BNB Smart Chain testnet RPC endpoint.
BSC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Anthropic API key used for pytest generation.
ANTHROPIC_API_KEY=

# Deployed ERC-8183 JobFactory address (reused deployment on BSC testnet).
ERC8183_ADDRESS=0x3464e64dD53bC093c53050cE5114062765e9F1b6

# Deployed GraderEvaluator contract address.
GRADER_EVALUATOR_ADDRESS=

# LLM provider selection: "anthropic" (default) or "openai" (OpenAI-compatible, e.g. LMStudio).
LLM_PROVIDER=anthropic
OPENAI_BASE_URL=
OPENAI_API_KEY=lm-studio
OPENAI_MODEL=qwen2.5-coder-7b-instruct-mlx

# Claude/Anthropic model id (override when switching snapshots).
ANTHROPIC_MODEL=claude-opus-4-7

# Optional relayer key for submitVerdict gas. Falls back to EVALUATOR_PRIVATE_KEY.
DEPLOYER_PRIVATE_KEY=

# Public URL used to build pytest_uri returned from /api/v1/grader/generate.
# Local dev: http://localhost:8000 ; Railway: https://<your-app>.up.railway.app
GRADER_PUBLIC_BASE_URL=http://localhost:8000

# x402 hint price in wei (default 0.01 tUSDT-equivalent when 18-decimal).
X402_PRICE_WEI=10000000000000000

# USDT / tUSDT address (documented for frontend; not read directly by grader).
USDT_ADDRESS=

# Alias for ERC8183_ADDRESS used in the frontend integration plan.
JOB_FACTORY_ADDRESS=

# On-disk persistence dir for tasks + pytest files.
DATA_DIR=./grader/data

# --- CORS ---
# Comma-separated allowed origins for browser clients.
# Unset default: http://localhost:3000 (local Next.js dev).
# Use "*" for wide-open demo, or pin to Vercel + localhost for prod:
# CORS_ALLOW_ORIGINS=https://your-app.vercel.app,http://localhost:3000
CORS_ALLOW_ORIGINS=

# --- Runtime ---
# Railway injects PORT; the Dockerfile CMD honors it. Default 8000 for local.
PORT=8000
