# AgentWork frontend — copy to .env.local and fill in values.

# Required: public URL of the grader FastAPI service.
NEXT_PUBLIC_GRADER_URL=http://localhost:8000

# Optional: WalletConnect Cloud project id. RainbowKit works without one,
# but WalletConnect-based wallets (mobile QR) require it.
# Get one at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
